{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sidereal Desk",
  "version": "0.3.0",
  "identifier": "com.young.sidereal-desk",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sidereal Desk",
        "width": 360,
        "height": 520,
        "minWidth": 280,
        "minHeight": 320,
        "center": false,
        "x": 48,
        "y": 48,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "maximizable": false,
        "skipTaskbar": false,
        "alwaysOnTop": true,
        "visible": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://ipapi.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
